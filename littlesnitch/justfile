name := "littlesnitch"
packages := "littlesnitch"
upholds := "littlesnitch"

import '../sysext.just'

all: default

# Custom download step to get the RPMs
# TODO: Automate version bumps
download-rpms target arch=arch:
    #!/bin/bash
    set -euo pipefail
    if [[ -n "{{debug}}" ]]; then
      set -x
    fi

    mkdir rpms
    cd rpms

    arch="{{arch}}"
    version="1.0.8-1"
    if [[ "${arch}" == "x86_64" ]]; then
        sha256sum="c5b69a8463cfa664514c3c735e9b5ae8ffeea480dfa06d175a12669bb47fdf73"
    else
        sha256sum="36c6f78d9e13847c624585e58d5beb2ad1d3abf17d8e56ace33286bb509bb9f4"
    fi

    echo "⬇️ Downloading littlesnitch"
    base_url="https://obdev.at/downloads/littlesnitch-linux"
    if ! curl --location --fail --output "littlesnitch-${version}.${arch}.rpm" \
        "${base_url}/littlesnitch-${version}.${arch}.rpm"; then
        echo "⚠️  Not found in main folder, trying legacy folder"
        curl --location --fail --output "littlesnitch-${version}.${arch}.rpm" \
            "${base_url}/legacy/littlesnitch-${version}.${arch}.rpm"
    fi
    echo "${sha256sum}  littlesnitch-${version}.${arch}.rpm" | sha256sum --check
