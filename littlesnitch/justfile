name := "littlesnitch"
packages := "littlesnitch"
upholds := "littlesnitch"

import '../sysext.just'

all: default

# Custom download step to get the RPMs
download-rpms target arch=arch:
    #!/bin/bash
    set -euo pipefail
    if [[ -n "{{debug}}" ]]; then
      set -x
    fi

    mkdir rpms
    cd rpms

    arch="{{arch}}"

    {{retry_function}}

    base_url="https://obdev.at/downloads/littlesnitch-linux"

    echo "🔍 Fetching latest version"
    retry 5 60 curl --location --fail --silent "${base_url}/latest-version.txt" --output latest_version
    version="$(cat latest_version | tr -d '[:space:]')"
    if [[ -z "${version}" ]]; then
        echo "❌ Failed to determine latest version"
        exit 1
    fi
    echo "📦 Latest version: ${version}"
    rm latest_version

    echo "🔍 Fetching hashes file"
    hashes_file="littlesnitch-${version}.hashes.txt"
    retry 5 60 curl --location --fail --silent --output "${hashes_file}" \
        "${base_url}/${hashes_file}"

    rpm_line="$(grep -E "  littlesnitch-${version}-[0-9]+\.${arch}\.rpm$" "${hashes_file}" | head -n1)"
    if [[ -z "${rpm_line}" ]]; then
        echo "❌ No matching RPM found for ${arch} in ${hashes_file}"
        exit 1
    fi
    sha256sum_expected="$(echo "${rpm_line}" | awk '{print $1}')"
    rpm_filename="$(echo "${rpm_line}" | awk '{print $2}')"

    echo "⬇️ Downloading ${rpm_filename}"
    retry 5 60 curl --location --fail --output "${rpm_filename}" \
        "${base_url}/${rpm_filename}"
    echo "${sha256sum_expected}  ${rpm_filename}" | sha256sum --check
    rm "${hashes_file}"
